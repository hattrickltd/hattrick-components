{
  "name": "@hattrickltd/hattrick-components",
  "version": "0.3.4",
  "description": "Web components for Hattrick.org.",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "es2015": "dist/esm/index.esm.js",
  "es2017": "dist/esm/index.esm.js",
  "jsnext:main": "dist/esm/index.esm.js",
  "types": "dist/types/components.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/components.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs.js",
      "default": "./dist/index.js"
    },
    "./components": {
      "types": "./dist/types/components.d.ts",
      "default": "./dist/components/index.js"
    },
    "./components/*.js": {
      "types": "./dist/components/*.d.ts",
      "default": "./dist/components/*.js"
    },
    "./loader": {
      "import": "./dist/loader/index.es2017.js",
      "default": "./dist/loader/index.js"
    }
  },
  "collection": "dist/collection/collection-manifest.json",
  "collection:main": "dist/collection/index.js",
  "files": [
    "dist/"
  ],
  "scripts": {
    "build": "npm run build:angular",
    "build:stencil": "stencil build",
    "build:angular": "npm run build:stencil && npm --prefix packages/angular-workspace run build",
    "publish:angular": "npm publish ./packages/angular-workspace/dist/hattrick-components --access=public",
    "dev": "stencil build --dev --watch --serve",
    "start": "npm run dev",
    "test": "stencil-test --prod",
    "test:unit": "stencil-test --project unit",
    "test:spec": "stencil-test --project spec",
    "test.watch": "stencil-test --prod --watch"
  },
  "dependencies": {
    "@floating-ui/dom": "^1.6.3"
  },
  "devDependencies": {
    "@stencil/angular-output-target": "^1.3.1",
    "@stencil/core": "^4.43.4",
    "@stencil/eslint-plugin": "^1.3.0",
    "@stencil/vitest": "^1.11.6",
    "eslint": "^9.0.0",
    "prettier": "^3.2.5",
    "tslint": "^5.17.0",
    "vitest": "^4.1.5",
    "workbox-build": "4.3.1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hattrickltd/hattrick-components.git"
  },
  "author": "Marcus Bodin <marcus@hattrick.org>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/hattrickltd/hattrick-components/issues"
  },
  "homepage": "https://github.com/hattrickltd/hattrick-components",
  "keywords": [
    "hattrick",
    "webcomponents"
  ]
}
