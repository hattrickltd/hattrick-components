{
  "name": "@hattrickltd/hattrick-components-angular",
  "version": "0.3.5",
  "description": "Angular wrappers for @hattrickltd/hattrick-components.",
  "license": "MIT",
  "type": "module",
  "module": "dist/hattrick-components/fesm2022/hattrickltd-hattrick-components-angular.mjs",
  "typings": "dist/hattrick-components/types/hattrickltd-hattrick-components-angular.d.ts",
  "sideEffects": true,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "prebuild": "node -e \"const fs=require('fs'); const missing=['src/lib/stencil-generated/components.ts','src/lib/stencil-generated/index.ts'].filter((file)=>!fs.existsSync(file)); if (missing.length) { console.error('Missing generated Stencil Angular proxies. Run npm run build:stencil from the repo root first.'); process.exit(1); }\"",
    "build": "ng-packagr -p ng-package.json"
  },
  "peerDependencies": {
    "@angular/common": "^18.2.0 || ^19.0.0 || ^20.0.0 || ^21.0.0",
    "@angular/core": "^18.2.0 || ^19.0.0 || ^20.0.0 || ^21.0.0",
    "rxjs": "^7.8.0"
  },
  "dependencies": {
    "@hattrickltd/hattrick-components": "^0.3.4",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/common": "^21.2.12",
    "@angular/compiler": "^21.2.12",
    "@angular/compiler-cli": "^21.2.12",
    "@angular/core": "^21.2.12",
    "ng-packagr": "^21.2.3",
    "rxjs": "^7.8.0",
    "typescript": "^5.9.3"
  }
}
